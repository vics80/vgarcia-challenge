<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Vgarcia Challenge PHPMD rules"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0
                             https://pmd.github.io/schema/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="https://pmd.github.io/schema/ruleset_xml_schema.xsd">
    <description>Default PHPMD rule sets adapted to the project's DDD style.</description>

    <exclude-pattern>*/tests/*</exclude-pattern>

    <rule ref="rulesets/cleancode.xml">
        <exclude name="StaticAccess"/>
    </rule>
    <rule ref="rulesets/codesize.xml">
        <exclude name="TooManyPublicMethods"/>
    </rule>
    <rule ref="rulesets/codesize.xml/TooManyPublicMethods">
        <properties>
            <property name="maxmethods" value="15"/>
            <property name="ignorepattern" value="(^(set|get|is|has|with))i"/>
        </properties>
    </rule>
    <rule ref="rulesets/design.xml">
        <exclude name="NumberOfChildren"/>
    </rule>
    <rule ref="rulesets/naming.xml">
        <exclude name="LongVariable"/>
        <exclude name="LongClassName"/>
    </rule>
    <rule ref="rulesets/naming.xml/LongVariable">
        <properties>
            <property name="maximum" value="40"/>
        </properties>
    </rule>
    <rule ref="rulesets/naming.xml/LongClassName">
        <properties>
            <property name="maximum" value="60"/>
            <property name="subtract-suffixes" value="CommandHandler,ConsoleCommand"/>
        </properties>
    </rule>
    <rule ref="rulesets/unusedcode.xml">
        <exclude name="UnusedFormalParameter"/>
    </rule>
</ruleset>
